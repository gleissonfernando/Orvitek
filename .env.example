# Config compacta para hospedagem com limite de variaveis.
# Use UMA destas opcoes no painel da hospedagem:
#
# 1) APP_CONFIG_JSON com o JSON completo.
# 2) APP_CONFIG_B64 com o mesmo JSON convertido para Base64.
#
# Nunca coloque valores reais neste arquivo ou no Git.

APP_CONFIG_JSON='{"SITE_ORIGIN":"https://seu-dominio.example.com","FRONTEND_URL":"https://seu-dominio.example.com","MONGODB_URI":"mongodb+srv://usuario:senha@cluster.example.net/nome-do-banco?retryWrites=true&w=majority","SESSION_SECRET":"gere-um-segredo-forte-de-sessao","JWT_SECRET":"gere-um-segredo-forte-de-jwt","BOT_API_TOKEN":"gere-um-token-interno-para-backend-e-bot","DISCORD_BOT_TOKEN":"token-do-bot-discord","DISCORD_CLIENT_ID":"client-id-oauth","DISCORD_CLIENT_SECRET":"client-secret-oauth","DISCORD_OAUTH_REDIRECT_URI":"https://seu-dominio.example.com/auth/discord/callback","DISCORD_CALLBACK_URL":"https://seu-dominio.example.com/auth/discord/callback","DISCORD_SCOPES":"identify email guilds guilds.members.read","DASHBOARD_DEV_USER_IDS":"id-discord-dev-1,id-discord-dev-2","DASHBOARD_GUILD_IDS":"id-servidor-discord-1,id-servidor-discord-2","BOT_COMMAND_GUILD_IDS":"","DASHBOARD_VERIFICATION_MODE":"roles","REDIS_SESSION_ENABLED":"false","REDIS_URL":"redis://usuario:senha@redis.example.com:6379","TWITCH_CLIENT_ID":"client-id-da-twitch","TWITCH_CLIENT_SECRET":"client-secret-da-twitch","TWITCH_BROADCASTER_ACCESS_TOKEN":"token-do-broadcaster-com-scopes","TWITCH_OAUTH_REDIRECT_URI":"https://seu-dominio.example.com/api/giveaways/oauth/twitch/callback","TWITCH_MONITOR_INTERVAL_MS":"20000","KICK_CLIENT_ID":"client-id-da-kick","KICK_CLIENT_SECRET":"api-key-ou-client-secret-da-kick","KICK_OAUTH_REDIRECT_URI":"https://seu-dominio.example.com/api/giveaways/oauth/kick/callback","KICK_WEBHOOK_PUBLIC_KEY":"","KICK_MONITOR_INTERVAL_MS":"30000","CLIPS_MAX_PER_CHECK":"3","CLIPS_LOOKBACK_MS":"900000","X_CONSUMER_KEY":"consumer-key-do-x","X_CONSUMER_SECRET":"consumer-secret-do-x","X_BEARER_TOKEN":"bearer-token-do-x","X_MONITOR_INTERVAL_MS":"60000"}'

# Alternativa quando o painel da hospedagem nao aceita JSON com aspas:
APP_CONFIG_B64=""

# Variaveis soltas ainda funcionam e sobrescrevem o JSON quando existirem.
# Exemplo:
# DASHBOARD_BOT_ID=""
# Em producao, mantenha leve por padrao e habilite apenas o necessario:
# BOT_ENABLED_MODULES="giveaway,logs,welcome,leave"
# BOT_DEFAULT_ALL_MODULES="false"
# START_REGISTERED_DEV_BOTS="true"
