# Arquivo seguro para versionar.
# Copie para .env localmente ou cadastre os valores reais no painel da hospedagem.
# Nunca coloque tokens, senhas ou secrets reais neste arquivo.

# Dominio publico da hospedagem, sem barra no final.
SITE_ORIGIN="https://ricardinho98.shardweb.app"
FRONTEND_URL="https://ricardinho98.shardweb.app"

# Banco principal MongoDB.
MONGODB_URI="mongodb+srv://usuario:senha@cluster.mongodb.net/nome-do-banco?retryWrites=true&w=majority"

# Segredos fortes e diferentes entre si.
SESSION_SECRET="troque-por-um-segredo-grande-de-sessao"
JWT_SECRET="troque-por-um-segredo-grande-de-jwt"
BOT_API_TOKEN="troque-por-um-token-interno-do-bot"
# Opcional: ID interno do bot cadastrado no painel Dev. Deixe vazio no bot principal legado.
DASHBOARD_BOT_ID=""

# Otimizacao de RAM do bot.
BOT_MEMBER_EVENTS_ENABLED="true"
BOT_MESSAGE_LOGS_ENABLED="false"
BOT_PRESENCE_MONITOR_ENABLED="false"
BOT_CACHE_MEMBERS_MAX="200"
BOT_CACHE_MESSAGES_PER_CHANNEL="10"
BOT_CACHE_PRESENCES_MAX="0"
BOT_CACHE_USERS_MAX="200"

# Discord.
DISCORD_BOT_TOKEN="token-do-bot"
DISCORD_CLIENT_ID="client-id-oauth"
DISCORD_CLIENT_SECRET="client-secret-oauth"
DISCORD_OAUTH_REDIRECT_URI="https://ricardinho98.shardweb.app/auth/discord/callback"
DISCORD_CALLBACK_URL="https://ricardinho98.shardweb.app/auth/discord/callback"
DISCORD_SCOPES="identify email guilds"

# Producao nao usa login local/dev.
DASHBOARD_AUTH_REQUIRED="true"
DASHBOARD_AUTHORIZED_USER_IDS="761011766440230932"
DASHBOARD_DEV_USER_IDS="1426287249020158018"
DASHBOARD_GUILD_IDS="1213384118356803594"
DEV_AUTH_ENABLED="false"
DASHBOARD_VERIFICATION_MODE="roles"

# O bot usa FRONTEND_URL por padrao.
# Configure apenas se API/socket ficarem em outro dominio.
# BACKEND_API_URL="https://api.seu-dominio.com/api"
# BACKEND_SOCKET_URL="https://api.seu-dominio.com"

# O frontend usa /api e o dominio atual por padrao no build.
# Configure apenas se usar dominios separados.
# VITE_API_URL="https://api.seu-dominio.com/api"
# VITE_SOCKET_URL="https://api.seu-dominio.com"

# Opcionais.
REDIS_URL=""
REDIS_SESSION_ENABLED="false"
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""
TWITCH_MONITOR_INTERVAL_MS="20000"
