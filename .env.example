# Copie estes nomes para o painel da hospedagem. Nao use localhost em producao.
NODE_ENV="production"
# Em producao na Shard, o codigo forca HOST=0.0.0.0 e PORT=80.

# Dominio publico da hospedagem, sem barra no final.
FRONTEND_URL="https://ricardinho98.shardweb.app"

# Obrigatorio para o Prisma/MongoDB em producao.
MONGODB_URI="mongodb+srv://usuario:senha@cluster.mongodb.net/ricardinho98?retryWrites=true&w=majority"

# Segredos fortes, diferentes entre si.
SESSION_SECRET="troque-por-um-segredo-grande-de-sessao"
JWT_SECRET="troque-por-um-segredo-grande-de-jwt"
BOT_API_TOKEN="troque-por-um-token-interno-do-bot"

# Discord.
DISCORD_BOT_TOKEN="token-do-bot"
DISCORD_CLIENT_ID="client-id-oauth"
DISCORD_CLIENT_SECRET="client-secret-oauth"
DISCORD_CALLBACK_URL="https://ricardinho98.shardweb.app/auth/discord/callback"
DISCORD_SCOPES="identify email guilds"

# Producao nao usa login local/dev.
DASHBOARD_AUTH_REQUIRED="true"
DASHBOARD_AUTHORIZED_USER_IDS="123456789012345678,987654321098765432"
DEV_AUTH_ENABLED="false"
DASHBOARD_VERIFICATION_MODE="temporary"

# O bot usa FRONTEND_URL por padrao. Configure estes dois apenas se API/socket ficarem em outro dominio.
# BACKEND_API_URL="https://api.seu-dominio.com/api"
# BACKEND_SOCKET_URL="https://api.seu-dominio.com"

# O frontend usa /api e o dominio atual por padrao no build. Configure apenas se usar dominios separados.
# VITE_API_URL="https://api.seu-dominio.com/api"
# VITE_SOCKET_URL="https://api.seu-dominio.com"

# Opcionais.
REDIS_URL=""
REDIS_SESSION_ENABLED="false"
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""
TWITCH_MONITOR_INTERVAL_MS="300000"
