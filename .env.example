# Config compacta para Discloud ou outra hospedagem com limite de variaveis.
# Use UMA destas opcoes no painel da Discloud:
#
# 1) APP_CONFIG_JSON com o JSON completo.
# 2) APP_CONFIG_B64 com o mesmo JSON convertido para Base64.
#
# Nunca coloque valores reais neste arquivo ou no Git.

APP_CONFIG_JSON='{"SITE_ORIGIN":"https://seu-dominio.example.com","FRONTEND_URL":"https://seu-dominio.example.com","BACKEND_URL":"https://seu-dominio.example.com","MONGODB_URI":"mongodb+srv://usuario:senha@cluster.example.net/nome-do-banco?retryWrites=true&w=majority","SESSION_SECRET":"gere-um-segredo-forte-de-sessao","JWT_SECRET":"gere-um-segredo-forte-de-jwt","BOT_API_TOKEN":"gere-um-token-interno-para-backend-e-bot","MASTER_TRANSCRIPT_PASSWORD":"NPD Lua Bennett","MASTER_TRANSCRIPT_PASSWORD_HASH":"","DISCORD_BOT_TOKEN":"token-do-bot-discord","DISCORD_CLIENT_ID":"client-id-oauth","DISCORD_CLIENT_SECRET":"client-secret-oauth","DISCORD_REDIRECT_URI":"https://seu-dominio.example.com/auth/discord/callback","DISCORD_OAUTH_REDIRECT_URI":"https://seu-dominio.example.com/auth/discord/callback","DISCORD_CALLBACK_URL":"https://seu-dominio.example.com/auth/discord/callback","DISCORD_SCOPES":"identify connections guilds guilds.join","DASHBOARD_DEV_USER_IDS":"id-discord-dev-1,id-discord-dev-2","DASHBOARD_GUILD_IDS":"id-servidor-discord-1,id-servidor-discord-2","BOT_COMMAND_GUILD_IDS":"","DASHBOARD_VERIFICATION_MODE":"roles","START_REGISTERED_DEV_BOTS":"true","REDIS_SESSION_ENABLED":"false","REDIS_URL":"redis://usuario:senha@redis.example.com:6379","TWITCH_CLIENT_ID":"client-id-da-twitch","TWITCH_CLIENT_SECRET":"client-secret-da-twitch","TWITCH_BROADCASTER_ACCESS_TOKEN":"token-do-broadcaster-com-scopes","TWITCH_OAUTH_REDIRECT_URI":"https://seu-dominio.example.com/api/giveaways/oauth/twitch/callback","TWITCH_MONITOR_INTERVAL_MS":"20000","KICK_CLIENT_ID":"client-id-da-kick","KICK_CLIENT_SECRET":"api-key-ou-client-secret-da-kick","KICK_OAUTH_REDIRECT_URI":"https://seu-dominio.example.com/api/giveaways/oauth/kick/callback","KICK_WEBHOOK_PUBLIC_KEY":"","KICK_MONITOR_INTERVAL_MS":"30000","CLIPS_MAX_PER_CHECK":"3","CLIPS_LOOKBACK_MS":"900000","X_CONSUMER_KEY":"consumer-key-do-x","X_CONSUMER_SECRET":"consumer-secret-do-x","X_BEARER_TOKEN":"bearer-token-do-x","X_MONITOR_INTERVAL_MS":"60000"}'

# Alternativa quando o painel da hospedagem nao aceita JSON com aspas:
APP_CONFIG_B64=""

# Variaveis soltas ainda funcionam e sobrescrevem o JSON quando existirem.
# Exemplo:
# PAYMENTS_ENABLED="false"
# PAYMENT_PROVIDER="disabled"
# PLAN_TOKEN_ENCRYPTION_KEY="gere-uma-chave-forte-para-criptografar-tokens-de-bot"
# PLAN_TOKEN_FINGERPRINT_KEY="gere-uma-chave-forte-para-fingerprint-de-tokens"
# PLAN_TOKEN_KEY_VERSION="v1"
# DASHBOARD_BOT_ID=""
# BACKEND_URL="https://seu-dominio.example.com"
# DISCORD_REDIRECT_URI="https://seu-dominio.example.com/auth/discord/callback"
# MASTER_TRANSCRIPT_PASSWORD="NPD Lua Bennett"
# MASTER_TRANSCRIPT_PASSWORD_HASH=""
# Discloud: configure somente no painel/ambiente seguro, nunca no Git.
# DISCLOUD_TOKEN=""
# Opcional: JSON {"botId-ou-clientId":"appId"} para vincular bots cadastrados a apps Discloud.
# DISCLOUD_APP_ID_BY_BOT=""
# Opcional: lista CSV de app IDs extras quando nao houver bot cadastrado correspondente.
# DISCLOUD_APP_IDS=""
# Em producao, mantenha leve por padrao e habilite apenas o necessario:
# BOT_ENABLED_MODULES="giveaway,logs,welcome,leave"
# BOT_DEFAULT_ALL_MODULES="false"
# Nó Lavalink v4 externo, configurado com lavalink/application.yml.
# LAVALINK_URL="http://127.0.0.1:2333"
# LAVALINK_PASSWORD="troque-esta-senha"
# SPOTIFY_CLIENT_ID=""
# SPOTIFY_CLIENT_SECRET=""
# Limites leves do Protecao/SafeBot. Tambem podem ir dentro de APP_CONFIG_JSON.
# SECURITY_MAX_ACTIONS_PER_MINUTE="40"
# SECURITY_MAX_DELETES_PER_MINUTE="20"
# SECURITY_MAX_KICKS_PER_MINUTE="4"
# SECURITY_MAX_BANS_PER_MINUTE="2"
# SECURITY_MAX_ROLE_UPDATES_PER_MINUTE="10"
# SECURITY_BACKUP_COOLDOWN_MINUTES="60"
# SECURITY_CLEANUP_BATCH_SIZE="10"
# SECURITY_SAFE_MODE_ERROR_LIMIT="8"
# SECURITY_SAFE_MODE_TIME_MINUTES="10"
# Ligue todos os bots cadastrados junto com o backend depois de deploy/restart somente se necessario.
START_REGISTERED_DEV_BOTS="false"
