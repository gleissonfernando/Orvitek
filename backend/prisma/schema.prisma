generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

model User {
  id           String   @id @default(cuid()) @map("_id")
  discordId    String   @unique
  username     String
  avatar       String?
  email        String?
  accessToken  String?
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  logs         LogEntry[]
}

model Guild {
  id          String          @id @map("_id")
  name        String
  icon        String?
  ownerId     String?
  botEnabled  Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  settings    GuildSettings?
  liveConfigs LiveConfig[]
  socialNotifications SocialNotification[]
  tickets     Ticket[]
  logs        LogEntry[]
  statistics  Statistic[]
}

model GuildSettings {
  id                  String   @id @default(cuid()) @map("_id")
  guildId             String   @unique
  guild               Guild    @relation(fields: [guildId], references: [id])
  welcomeEnabled      Boolean  @default(false)
  welcomeChannelId    String?
  welcomeMessage      String?
  autoRoleEnabled     Boolean  @default(false)
  autoRoleIds         String[] @default([])
  twitchRoleId        String?
  boosterRoleId       String?
  ticketEnabled       Boolean  @default(false)
  ticketCategoryId    String?
  logChannelId        String?
  moderationEnabled   Boolean  @default(true)
  verificationEnabled Boolean  @default(false)
  verificationRoleId  String?
  updatedAt           DateTime @updatedAt
}

model LiveConfig {
  id         String   @id @default(cuid()) @map("_id")
  guildId    String
  guild      Guild    @relation(fields: [guildId], references: [id])
  streamerId String
  streamer   String
  platform   String   @default("twitch")
  channelId  String?
  roleId     String?
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([guildId, platform, streamerId])
}

model Ticket {
  id        String       @id @default(cuid()) @map("_id")
  guildId   String
  guild     Guild        @relation(fields: [guildId], references: [id])
  channelId String?
  openerId  String
  subject   String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  closedAt  DateTime?
}

model LogEntry {
  id        String   @id @default(cuid()) @map("_id")
  guildId   String
  guild     Guild    @relation(fields: [guildId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([guildId, createdAt])
}

model Statistic {
  id           String   @id @default(cuid()) @map("_id")
  guildId      String
  guild        Guild    @relation(fields: [guildId], references: [id])
  memberCount  Int      @default(0)
  channelCount Int      @default(0)
  liveCount    Int      @default(0)
  ticketCount  Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([guildId, createdAt])
}

model SocialNotification {
  id                String   @id @default(cuid()) @map("_id")
  guildId           String
  guild             Guild    @relation(fields: [guildId], references: [id])
  userId            String
  platform          String   @default("twitch")
  twitchChannelName String
  twitchChannelUrl  String
  twitchUserId      String?
  twitchAvatar      String?
  discordChannelId  String
  mentionRoleId     String?
  customMessage     String?
  enabled           Boolean  @default(true)
  isLive            Boolean  @default(false)
  lastStreamId      String?
  lastMessageId     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([guildId, platform, twitchChannelName])
  @@index([guildId, platform])
  @@index([platform, enabled])
  @@map("social_notifications")
}

enum TicketStatus {
  OPEN
  PENDING
  CLOSED
}
