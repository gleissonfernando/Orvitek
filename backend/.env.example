NODE_ENV="development"
PORT="4000"
DATABASE_URL="postgresql://discord:discord@localhost:5432/discord_platform?schema=public"
REDIS_URL="redis://localhost:6379"
REDIS_SESSION_ENABLED="false"
SESSION_SECRET="change-this-session-secret"
SESSION_TTL_SECONDS="604800"
JWT_SECRET="change-this-jwt-secret"
JWT_ACCESS_TTL_SECONDS="900"
JWT_REFRESH_TTL_SECONDS="604800"
BOT_API_TOKEN="change-this-shared-token"

DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_CALLBACK_URL="http://localhost:4000/api/auth/discord/callback"
DISCORD_SCOPES="identify email guilds"

FRONTEND_URL="http://localhost:5173"
DASHBOARD_AUTH_REQUIRED="false"
DASHBOARD_VERIFICATION_MODE="temporary"
DEV_AUTH_ENABLED="false"
